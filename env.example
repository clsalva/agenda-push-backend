// Test end-to-end del backend usando pg-mem (Postgres emulato in memoria)
// invece di un vero DB. Verifica che tutte le rotte rispondano correttamente
// e che la logica di sync + reminder funzioni.
const { newDb } = require('pg-mem');
const fs = require('fs');
const path = require('path');
const Module = require('module');

process.env.PUBLIC_VAPID_KEY = 'BADZgNmVCqtaSwTyEW2Q0-I7JhwPxdwNaShg0JI1PrLF4SBaiF_5kJbSys6P_SwEb_TOuUd583Rc5W-Y8OlqOFo';
process.env.PRIVATE_VAPID_KEY = 'pN_L2tvv-oVBtG0_dzdrwNhpBoNWNQZnAHyqHXA3vWQ';
process.env.DATABASE_URL = 'postgres://fake:fake@localhost:5432/fake';
process.env.APP_TOKEN = 'my-secret-token';
process.env.CRON_SECRET = 'cron-secret-123';
process.env.PORT = '8091';
process.env.ALLOWED_ORIGIN = '*';

const db = newDb({ autoCreateForeignKeyIndices: true });
db.public.registerFunction({
  name: 'now',
  returns: 'timestamp',
  implementation: () => new Date()
});
const schema = fs.readFileSync(path.join(__dirname, '..', 'schema.sql'), 'utf8');
db.public.none(schema);

const { Pool } = db.adapters.createPg();
const fakePgModule = { Pool };

// Intercetta require('pg') SOLO per il processo di test, così index.js/db.js
// (che non vengono modificati) parlano con pg-mem invece che con un DB vero.
const originalResolve = Module._resolveFilename;
Module._resolveFilename = function (request, ...args) {
  if (request === 'pg') return 'pg-mem-shim';
  return originalResolve.call(this, request, ...args);
};
require.cache['pg-mem-shim'] = { id: 'pg-mem-shim', filename: 'pg-mem-shim', loaded: true, exports: fakePgModule };

let sentPushes = [];
const webpush = require('web-push');
webpush.sendNotification = async (sub, payload) => {
  sentPushes.push({ endpoint: sub.endpoint, payload: JSON.parse(payload) });
  return { statusCode: 201 };
};

require('../index.js');

async function main() {
  await new Promise((r) => setTimeout(r, 300));
  const base = 'http://localhost:8091';
  const authHeaders = { 'Content-Type': 'application/json', 'x-app-token': 'my-secret-token' };
  const results = [];

  const health = await fetch(base + '/').then((r) => r.json());
  results.push(['GET /', health.ok === true]);

  const noAuth = await fetch(base + '/api/items');
  results.push(['GET /api/items senza token -> 401', noAuth.status === 401]);

  const emptyItems = await fetch(base + '/api/items', { headers: authHeaders }).then((r) => r.json());
  results.push(['GET /api/items vuoto iniziale', Array.isArray(emptyItems.data.appointments) && emptyItems.data.appointments.length === 0]);

  const dueId = 'item-due-1';
  const futureId = 'item-future-1';
  const putRes = await fetch(base + '/api/items', {
    method: 'PUT',
    headers: authHeaders,
    body: JSON.stringify({
      appointments: [
        { id: dueId, title: 'Dentista', reminderAt: new Date(Date.now() - 60000).toISOString(), notes: 'Portare tessera' }
      ],
      tasks: [
        { id: futureId, title: 'Task futuro', reminderAt: new Date(Date.now() + 3600000).toISOString() }
      ]
    })
  }).then((r) => r.json());
  results.push(['PUT /api/items salva stato', putRes.ok === true]);

  const getAfterPut = await fetch(base + '/api/items', { headers: authHeaders }).then((r) => r.json());
  results.push(['GET /api/items rilegge lo stato salvato', getAfterPut.data.appointments[0].id === dueId]);

  const subRes = await fetch(base + '/api/subscribe', {
    method: 'POST',
    headers: authHeaders,
    body: JSON.stringify({ endpoint: 'https://fcm.example.com/device-1', keys: { p256dh: 'x', auth: 'y' } })
  }).then((r) => r.json());
  results.push(['POST /api/subscribe salva subscription', subRes.ok === true]);

  const cronNoSecret = await fetch(base + '/api/cron/check-reminders');
  results.push(['GET cron senza secret -> 401', cronNoSecret.status === 401]);

  const cronRes = await fetch(base + '/api/cron/check-reminders?secret=cron-secret-123').then((r) => r.json());
  results.push(['GET cron con secret invia 1 reminder (solo quello scaduto)', cronRes.ok === true && cronRes.remindersSent === 1]);
  results.push(['La push è stata effettivamente "inviata" (mock)', sentPushes.length === 1 && sentPushes[0].payload.title === 'Dentista']);

  const cronRes2 = await fetch(base + '/api/cron/check-reminders?secret=cron-secret-123').then((r) => r.json());
  results.push(['Secondo giro cron: nessun reminder duplicato', cronRes2.remindersSent === 0]);

  console.log('\n--- RISULTATI TEST END-TO-END ---');
  let allOk = true;
  for (const [name, ok] of results) {
    console.log((ok ? 'OK   ' : 'FAIL ') + name);
    if (!ok) allOk = false;
  }
  console.log(allOk ? '\nTUTTI I TEST PASSATI' : '\nALCUNI TEST FALLITI');
  process.exit(allOk ? 0 : 1);
}

main().catch((err) => {
  console.error('Errore nel test:', err);
  process.exit(1);
});
